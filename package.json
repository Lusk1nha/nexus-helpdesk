{
  "name": "nexus-helpdesk",
  "version": "1.0.0",
  "description": "Nexus Helpdesk - Application to manage helpdesk tickets",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test:run",
    "test:watch": "turbo test",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "packageManager": "pnpm@10.7.1",
  "dependencies": {
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  }
}
