# Backend API base URL
VITE_API_URL=http://localhost:8080

# Template used to redirect to the tenant workspace after registration.
# Must contain the literal `{slug}` placeholder.
# Dev (subdomain on localhost):  http://{slug}.localhost:5173
# Dev (nexus.test in /etc/hosts): http://{slug}.nexus.test:5173
# Prod:                           https://{slug}.nexus.com
VITE_WORKSPACE_URL_TEMPLATE=http://{slug}.localhost:5173
