# =============================================================================
# Nexus Helpdesk — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Variables marked as REQUIRED have no defaults and will cause a startup panic
# if omitted.  All others have sane defaults shown below.
#
# Config is loaded in layers (last wins):
#   1. Defaults (built-in)
#   2. config.toml at the project root (optional, for per-machine overrides)
#   3. Environment variables / this .env file
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
# REQUIRED — PostgreSQL connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nexus_helpdesk

# ── Security ─────────────────────────────────────────────────────────────────
# REQUIRED — Secret used to sign and verify JWTs.
# Generate a strong value with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ── HTTP Server ───────────────────────────────────────────────────────────────
# IP address the server binds to.
# Default: 0.0.0.0
HOST=0.0.0.0

# TCP port the API listens on.
# Default: 8080
PORT=8080

# Allowed CORS origin for the frontend SPA.
# Default: http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ── AI Integrations ───────────────────────────────────────────────────────────
# Base URL of the local Ollama LLM server.
# Install: https://ollama.com  |  Pull model: ollama pull phi3
# Default: http://127.0.0.1:11434
OLLAMA_URL=http://127.0.0.1:11434

# Base URL of the Qdrant vector database (used for RAG / knowledge base).
# Start with Docker: docker run -p 6333:6333 -p 6334:6334 qdrant/qdrant
# Default: http://127.0.0.1:6334
QDRANT_URL=http://127.0.0.1:6334
