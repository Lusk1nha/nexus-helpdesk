# =============================================================================
# Nexus Helpdesk — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Variables marked as REQUIRED have no defaults and will cause a startup panic
# if omitted.  All others have sane defaults shown below.
#
# Config is loaded in layers (last wins):
#   1. Defaults (built-in)
#   2. config.toml at the project root (optional, for per-machine overrides)
#   3. Environment variables / this .env file
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
# REQUIRED — PostgreSQL connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nexus_helpdesk

# ── Security ─────────────────────────────────────────────────────────────────
# REQUIRED — Secret used to sign and verify JWTs (mínimo 32 caracteres).
# Generate a strong value with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-in-production-32chars

# Lifetime of access tokens, in minutes. Default: 15
ACCESS_TOKEN_TTL_MINUTES=15

# Lifetime of refresh tokens, in days. Default: 30
REFRESH_TOKEN_TTL_DAYS=30

# `iss` claim included in every JWT. Default: nexus-helpdesk
JWT_ISSUER=nexus-helpdesk

# ── HTTP Server ───────────────────────────────────────────────────────────────
# IP address the server binds to.
# Default: 0.0.0.0
HOST=0.0.0.0

# TCP port the API listens on.
# Default: 8080
PORT=8080

# Allowed CORS origins for frontend SPAs.
# Comma-separated list of exact origins OR wildcard-suffix patterns.
# Wildcard pattern: starts with "." and matches any subdomain.
#
# Plain localhost (no subdomains, simplest):
FRONTEND_URL=http://localhost:5173,http://localhost:5174,http://localhost:5175
#
# Subdomain mode (requires /etc/hosts + Caddy — see dev/README.md):
# FRONTEND_URL=.nexus.localhost
#
# Production:
# FRONTEND_URL=.nexus.com

# ── Cookies ──────────────────────────────────────────────────────────────────
# Domain attribute for the refresh token cookie.
# Leave unset (default) for host-scoped cookies on plain localhost ports.
# Set to ".nexus.localhost" to share the refresh token across all local subdomains.
# Set to ".nexus.com" in production.
# COOKIE_DOMAIN=.nexus.localhost

# Whether to require HTTPS for the cookie (Secure attribute).
# Must be true in production. Default: false.
# COOKIE_SECURE=false

# ── AI Integrations ───────────────────────────────────────────────────────────
# Base URL of the local Ollama LLM server.
# Install: https://ollama.com  |  Pull model: ollama pull phi3
# Default: http://127.0.0.1:11434
OLLAMA_URL=http://127.0.0.1:11434

# Base URL of the Qdrant vector database (used for RAG / knowledge base).
# Start with Docker: docker run -p 6333:6333 -p 6334:6334 qdrant/qdrant
# Default: http://127.0.0.1:6334
QDRANT_URL=http://127.0.0.1:6334
