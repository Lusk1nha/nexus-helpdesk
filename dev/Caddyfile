# Nexus Helpdesk — Local dev reverse proxy (HTTP only)
#
# O prefixo http:// em cada host desativa o auto-HTTPS do Caddy.
# Em produção, remova o prefixo e o Caddy emite certificados automaticamente.

http://api.nexus.localhost {
    reverse_proxy localhost:8080 {
        flush_interval -1
    }
}

http://onboarding.nexus.localhost {
    reverse_proxy localhost:5174
}

http://admin.nexus.localhost {
    reverse_proxy localhost:5175
}

http://*.nexus.localhost {
    reverse_proxy localhost:5173
}
